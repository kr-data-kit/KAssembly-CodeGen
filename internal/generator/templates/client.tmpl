// Response is a generic struct that represents the response from the Open Assembly API.
type Response[T any] struct {
	// Status indicates the result of the API call, such as success, no data, or various error conditions.
	Status APIStatus
	// Source indicates the origin of the data, such as "bulk-xls", "bulk-json", "api".
	Source string `json:"source,omitempty" xml:"source,omitempty"`
	// Data contains the actual records returned by the API, which may be empty if no data is available.
	Data []T
}

func fetchApi[T any](
    ctx context.Context,
    c *{{.ClientName}},
    endpoint string,
    params ApiParams,
) (Response[T], error) {
    url := c.buildURL(endpoint, params)
    body, err := c.fetchHTTP(ctx, url)
    if err != nil {
        return Response[T]{}, err
    }

    var raw map[string]json.RawMessage
    if err := json.Unmarshal(body, &raw); err != nil {
        return Response[T]{}, fmt.Errorf("failed to parse response: %w", err)
    }

    if resultData, ok := raw["RESULT"]; ok {
        var result Result
        if err := json.Unmarshal(resultData, &result); err != nil {
            return Response[T]{}, fmt.Errorf("failed to parse RESULT: %w", err)
        }
        if result.Code == "INFO-200" {
            return Response[T]{
                Status: StatusNoData,
                Source: "api",
            }, nil
        }
        status, ok := GetStatus(result.Code)
        if !ok {
            return Response[T]{}, fmt.Errorf("unknown API status code: %s", result.Code)
        }

        return Response[T]{Status: status, Source: "api"}, fmt.Errorf("API error: %s - %s", result.Code, result.Message)
    }

    data, ok := raw[endpoint]
    if !ok {
        return Response[T]{}, fmt.Errorf("unexpected response structure")
    }

    var item []Item[T]
    if err := json.Unmarshal(data, &item); err != nil {
        return Response[T]{}, fmt.Errorf("failed to parse data: %w", err)
    }
    if len(item) < 2 {
        return Response[T]{}, fmt.Errorf("insufficient data in response")
    }
    // FUTURE : 여기서 item[0]은 메타데이터, item[1]이 실제 데이터임을 보장해야 함
    return Response[T]{Data: item[1].Row, Status: StatusOK, Source: "api"}, nil
}
    

func (c *{{.ClientName}}) buildURL(endpoint string, paramStruct ApiParams) string {
	params := url.Values{}
	params.Add("KEY", c.Key)
	paramStruct.Encode(&params)
	return OpenAssemblyBaseURL + endpoint + "?" + params.Encode()
}

