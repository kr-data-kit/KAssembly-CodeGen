func (c *{{.ClientName}}) fetchHTTP(ctx context.Context, url string) ([]byte, error) {
    req, err := http.NewRequestWithContext(ctx, "GET", url, nil)
    if err != nil {
        return nil, err
    }
    c.setCommonHeaders(req)

    resp, err := c.Http.Do(req)
    if err != nil {
        return nil, err
    }
    defer resp.Body.Close()

    if resp.StatusCode != http.StatusOK {
        return nil, fmt.Errorf("HTTP request failed with status: %s", resp.Status)
    }

    body, err := io.ReadAll(resp.Body)
    if err != nil {
        return nil, err
    }
    return body, nil
}

func fetchBulkJson[T any](
	ctx context.Context,
	c *{{.ClientName}},
	infId string,
	infSeq string,
	param any,
) (Response[T], error) {
	form := url.Values{}
	setQueryParams(param, &form)
	form.Set("infId", infId)
	form.Set("infSeq", infSeq)
	form.Set("downloadType", "J")

	req, err := http.NewRequestWithContext(
		ctx,
		http.MethodPost,
		OpenAssemblyBulkJsonURL,
		strings.NewReader(form.Encode()),
	)
	if err != nil {
		return Response[T]{}, err
	}

	c.setCommonHeaders(req)
	req.Header.Set("Content-Type", "application/x-www-form-urlencoded")
	req.Header.Set("Accept-Encoding", "gzip")

	resp, err := c.Http.Do(req)
	if err != nil {
		return Response[T]{}, err
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusOK {
		return Response[T]{}, fmt.Errorf("HTTP request failed with status: %s", resp.Status)
	}

	var data []T
	if err := json.NewDecoder(resp.Body).Decode(&data); err != nil {
		return Response[T]{}, fmt.Errorf("failed to decode JSON response: %w", err)
	}
	if len(data) < 2 {
		return Response[T]{Status: StatusNoData, Source: "bulk-json"}, nil
	}
	return Response[T]{Data: data[1:], Status: StatusOK, Source: "bulk-json"}, nil
}

func setQueryParams(params any, value *url.Values) {
	t := reflect.TypeOf(params)
	for i := 0; i < t.NumField(); i++ {
		field := t.Field(i)
		if field.Anonymous {
			continue
		}
		queryTag := field.Tag.Get("query")
		if queryTag == "" {
			continue
		}
		value.Set(queryTag, "")
	}
}
